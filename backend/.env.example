# ==========================================
# API KEYS (Get these from each service)
# ==========================================

# Alpha Vantage - Stock prices & technicals
# Get from: https://alphavantage.co
ALPHA_VANTAGE_API_KEY=demo

# Finnhub - Analyst ratings & news
# Get from: https://finnhub.io
FINNHUB_API_KEY=c1234567890abcdef

# newsdata.io - Stock news & sentiment
# Get from: https://newsdata.io
NEWSDATA_API_KEY=pub_1234567890

# Financial Modeling Prep - Grades & price targets
# Get from: https://financialmodelingprep.com
FMP_API_KEY=demo

# SEC-API.io - Quarterly filings
# Get from: https://sec-api.io
SEC_API_KEY=demo

# ==========================================
# DATABASE SETTINGS
# ==========================================

DATABASE_PATH=../data/stocks.db

# ==========================================
# LOGGING SETTINGS
# ==========================================

LOG_LEVEL=info
LOG_FILE=./logs/app.log

# ==========================================
# MARKET TIMINGS (ET - Eastern Time)
# ==========================================

MARKET_OPEN=09:30
MARKET_CLOSE=16:00
MARKET_TIMEZONE=America/New_York

# Schedule time (ET) - when to fetch data
# Currently: 5:00 PM ET (1 hour after market close)
FETCH_SCHEDULE_HOUR=17
FETCH_SCHEDULE_MINUTE=0

# ==========================================
# APPLICATION MODE
# ==========================================

NODE_ENV=production
